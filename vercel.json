{
  "buildCommand": "cd mini_app && npm install && npm run build",
  "outputDirectory": "mini_app/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://jaqyn-dating-bot.onrender.com",
    "VITE_USE_MOCKS": "false"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
