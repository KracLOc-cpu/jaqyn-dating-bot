# ──────────────────────────────────────────────────────────────
#  Dating Bot — пример конфигурации. Скопируй в .env и заполни.
# ──────────────────────────────────────────────────────────────

# ── Telegram ──
BOT_TOKEN=123456:ABC-DEF_your_token_here
BOT_MODE=polling                      # polling (local) | webhook (prod)
WEBHOOK_URL=                          # https://api.yourdomain.com (только для webhook)
WEBHOOK_SECRET=change_me_random       # секрет для верификации webhook
MINI_APP_URL=https://app.yourdomain.com
MINI_APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# Админы (через запятую) — доступ к /admin/* ручкам
ADMIN_TELEGRAM_IDS=123456789

# ── PostgreSQL ──
POSTGRES_DB=dating_db
POSTGRES_USER=dating_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres                # имя сервиса в compose
POSTGRES_PORT=5432
# Для Supabase/Render можно вместо POSTGRES_* указать DATABASE_URL.
DATABASE_URL=

# ── Redis ──
USE_REDIS=true                        # free test on Render can use false
REDIS_URL=                            # optional external Redis URL
REDIS_HOST=redis
REDIS_PORT=6379
ONBOARDING_TTL=86400                  # сек, время жизни сессии онбординга (24ч)

# ── S3 / Object storage ──
# local  → MinIO  (S3_ENDPOINT=http://minio:9000)
# prod   → Cloudflare R2 (S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com)
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=dating-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
SIGNED_URL_TTL=3600                   # сек, время жизни signed URL фото

# MinIO root creds (только local; должны совпадать с S3_ACCESS_KEY/SECRET выше)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── App ──
ENV=local                             # local | prod
CORS_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:8080,https://app.yourdomain.com

# ── Mini App build ──
VITE_API_URL=http://localhost:8000
VITE_USE_MOCKS=true                   # local=true для разработки без Telegram initData; prod=false
